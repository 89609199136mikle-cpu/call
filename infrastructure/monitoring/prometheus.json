{
  "global": {
    "scrape_interval": "15s",
    "evaluation_interval": "15s",
    "external_labels": {
      "monitor": "crane-stack"
    }
  },
  "scrape_configs": [
    {
      "job_name": "prometheus",
      "static_configs": [
        {
          "targets": ["localhost:9090"]
        }
      ]
    },
    {
      "job_name": "crane-api-gateway",
      "metrics_path": "/metrics",
      "static_configs": [
        {
          "targets": ["crane-api-gateway:5000"]
        }
      ]
    },
    {
      "job_name": "crane-chat-service",
      "metrics_path": "/metrics",
      "static_configs": [
        {
          "targets": ["crane-chat-service:5001"]
        }
      ]
    },
    {
      "job_name": "crane-message-service",
      "metrics_path": "/metrics",
      "static_configs": [
        {
          "targets": ["crane-message-service:5002"]
        }
      ]
    },
    {
      "job_name": "redis-exporter",
      "static_configs": [
        {
          "targets": ["redis:9121"]
        }
      ]
    },
    {
      "job_name": "postgres-exporter",
      "static_configs": [
        {
          "targets": ["db:9187"]
        }
      ]
    }
  ]
}
