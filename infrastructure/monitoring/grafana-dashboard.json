{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "title": "Active Users Online (Redis Sessions)",
      "type": "stat",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "expr": "redis_db_keys{db=\"0\", key=\"presence:*\"}", "refId": "A" }],
      "options": { "colorMode": "value", "graphMode": "area" }
    },
    {
      "title": "Messages Throughput (Queue Load)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 0 },
      "targets": [{ "expr": "rate(crane_messages_processed_total[1m])", "refId": "B" }],
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20 } } }
    },
    {
      "title": "Active WebRTC Calls",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "expr": "crane_active_calls_count", "refId": "C" }],
      "options": { "reduceOptions": { "values": false, "calcs": ["lastNotNull"] } }
    },
    {
      "title": "Service Health (Gateway / Chat / Message)",
      "type": "table",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [{ "expr": "up{app=\"crane-messenger\"}", "refId": "D" }],
      "options": { "showHeader": true }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 36,
  "style": "dark",
  "tags": ["craneapp", "production", "railway"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
