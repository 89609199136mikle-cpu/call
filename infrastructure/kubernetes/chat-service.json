{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "crane-chat-service",
    "labels": {
      "app": "crane-messenger",
      "component": "chat-logic"
    }
  },
  "spec": {
    "replicas": 2,
    "strategy": {
      "type": "RollingUpdate",
      "rollingUpdate": {
        "maxSurge": 1,
        "maxUnavailable": 0
      }
    },
    "selector": {
      "matchLabels": {
        "component": "chat-logic"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "component": "chat-logic"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "chat-service",
            "image": "registry.railway.app/craneapp/server:latest",
            "command": ["node", "server/services/chat-service/chatService.js"],
            "ports": [
              {
                "container_port": 5001
              }
            ],
            "env": [
              {
                "name": "DATABASE_URL",
                "valueFrom": {
                  "secretKeyRef": { "name": "crane-db-secrets", "key": "url" }
                }
              },
              {
                "name": "REDIS_URL",
                "valueFrom": {
                  "secretKeyRef": { "name": "crane-redis-secrets", "key": "url" }
                }
              }
            ],
            "resources": {
              "requests": {
                "cpu": "150m",
                "memory": "256Mi"
              },
              "limits": {
                "cpu": "300m",
                "memory": "512Mi"
              }
            },
            "livenessProbe": {
              "tcpSocket": {
                "port": 5001
              },
              "initialDelaySeconds": 15,
              "periodSeconds": 20
            }
          }
        ]
      }
    }
  }
}
