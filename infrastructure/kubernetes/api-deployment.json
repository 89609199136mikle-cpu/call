{
  "apiVersion": "apps/v1",
  "kind": "Deployment",
  "metadata": {
    "name": "crane-api-gateway",
    "labels": {
      "app": "crane-messenger",
      "component": "api-gateway"
    }
  },
  "spec": {
    "replicas": 3,
    "selector": {
      "matchLabels": {
        "component": "api-gateway"
      }
    },
    "template": {
      "metadata": {
        "labels": {
          "component": "api-gateway"
        }
      },
      "spec": {
        "containers": [
          {
            "name": "api-gateway",
            "image": "registry.railway.app/craneapp/server:latest",
            "ports": [
              {
                "containerPort": 5000
              }
            ],
            "env": [
              {
                "name": "DATABASE_URL",
                "valueFrom": {
                  "secretKeyRef": {
                    "name": "crane-db-secrets",
                    "key": "url"
                  }
                }
              },
              {
                "name": "REDIS_URL",
                "valueFrom": {
                  "secretKeyRef": {
                    "name": "crane-redis-secrets",
                    "key": "url"
                  }
                }
              },
              {
                "name": "JWT_SECRET",
                "valueFrom": {
                  "secretKeyRef": {
                    "name": "crane-auth-secrets",
                    "key": "jwt-key"
                  }
                }
              }
            ],
            "resources": {
              "requests": {
                "cpu": "100m",
                "memory": "256Mi"
              },
              "limits": {
                "cpu": "500m",
                "memory": "512Mi"
              }
            },
            "readinessProbe": {
              "httpGet": {
                "path": "/api/auth/health",
                "port": 5000
              },
              "initialDelaySeconds": 5,
              "periodSeconds": 10
            }
          }
        ]
      }
    }
  }
}
